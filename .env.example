# Database Connection Settings
DATABASE_URL=postgresql://transport_user:transport_pass@postgres:5432/transport_db # Primary connection URL for the Postgres database
DATABASE_POOL_MIN=2 # Minimum number of connections to maintain in the pool
DATABASE_POOL_MAX=10 # Maximum number of connections to allow in the pool

# Cache / Redis Settings
REDIS_URL=redis://redis:6379 # Connection URL for the Redis server

# Authentication Configuration (JWT)
JWT_ACCESS_SECRET=your_jwt_access_secret_here # Secret key used to sign access tokens
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here # Secret key used to sign refresh tokens
JWT_ACCESS_EXPIRY=15m # Expiration time format for access tokens (e.g. 15m, 1h)
JWT_REFRESH_EXPIRY=7d # Expiration time format for refresh tokens (e.g. 7d, 30d)

# Google Maps API Configuration
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here # API Key for server-side Google Maps API requests
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here # API Key for client-side Google Maps components

# Frontend App Environment Settings (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4000 # Endpoint URL for backend REST API communication
NEXT_PUBLIC_SOCKET_URL=ws://localhost:4000 # Endpoint URL for real-time WebSocket communication

# Mail Transfer Settings (SMTP)
SMTP_HOST=smtp.mailtrap.io # Host address of the SMTP server
SMTP_PORT=2525 # Port number of the SMTP server (usually 25, 465, 587, or 2525)
SMTP_USER=your_smtp_username # Username authentication credential for the SMTP server
SMTP_PASS=your_smtp_password # Password authentication credential for the SMTP server

# Push Notification VAPID Keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here # Public key used for web push notifications subscription
VAPID_PRIVATE_KEY=your_vapid_private_key_here # Private key used for signing web push notifications
VAPID_SUBJECT=mailto:admin@transport.app # Contact email or website URL for push notifications payload

# Postgres Container Initialisation (Docker Compose)
POSTGRES_DB=transport_db # Database name created on container initialisation
POSTGRES_USER=transport_user # Admin user name created on container initialisation
POSTGRES_PASSWORD=transport_pass # Password for the admin user

# Server General Settings
API_PORT=4000 # Local port that the API server runs on
NODE_ENV=development # Application runtime environment (development, production, or test)
